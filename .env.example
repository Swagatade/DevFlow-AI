# Shared
APP_ENV=local

# Backend
DATABASE_URL=postgresql+asyncpg://bob:bob_password@localhost:5432/bob
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000
AUTO_CREATE_TABLES=true

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=bob_workspace

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=45

# Local repository downloads
# Leave empty to use ~/Downloads/DevFlow AI outside Docker.
DEVFLOW_DOWNLOAD_DIR=

# Frontend / Auth.js
AUTH_SECRET=replace-with-an-authjs-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
API_BASE_URL=http://localhost:8000/api/v1
