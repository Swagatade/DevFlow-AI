{
  "name": "ibm-bob",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable AI developer operations workspace.",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm --prefix frontend run dev\" \"cd apps/api && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000\"",
    "dev:web": "npm --prefix frontend run dev",
    "dev:api": "cd apps/api && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "typecheck": "npm --prefix frontend run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
